{
	"function": "stats-extended-2",
	"cases": [
		{
			"description": "NORM.S.DIST CDF at 0",
			"setup": {},
			"formula": "=NORM.S.DIST(0, TRUE)",
			"expected": { "kind": "number", "approx": 0.5, "tolerance": 0.001 }
		},
		{
			"description": "NORM.S.INV at 0.975",
			"setup": {},
			"formula": "=NORM.S.INV(0.975)",
			"expected": { "kind": "number", "approx": 1.96, "tolerance": 0.005 }
		},
		{
			"description": "PERCENTILE at 0.5 is median",
			"setup": { "A1": 1, "A2": 2, "A3": 3, "A4": 4, "A5": 5 },
			"formula": "=PERCENTILE(A1:A5, 0.5)",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "PERCENTILE.INC at 0.25",
			"setup": { "A1": 1, "A2": 2, "A3": 3, "A4": 4 },
			"formula": "=PERCENTILE.INC(A1:A4, 0.25)",
			"expected": { "kind": "number", "value": 1.75 }
		},
		{
			"description": "QUARTILE Q2 equals median",
			"setup": { "A1": 10, "A2": 20, "A3": 30, "A4": 40, "A5": 50 },
			"formula": "=QUARTILE(A1:A5, 2)",
			"expected": { "kind": "number", "value": 30 }
		},
		{
			"description": "GEOMEAN",
			"setup": { "A1": 4, "A2": 9 },
			"formula": "=GEOMEAN(A1:A2)",
			"expected": { "kind": "number", "value": 6 }
		},
		{
			"description": "HARMEAN",
			"setup": { "A1": 4, "A2": 4 },
			"formula": "=HARMEAN(A1:A2)",
			"expected": { "kind": "number", "value": 4 }
		},
		{
			"description": "MODE single mode",
			"setup": { "A1": 1, "A2": 2, "A3": 2, "A4": 3 },
			"formula": "=MODE(A1:A4)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "RANK ascending",
			"setup": { "A1": 30, "A2": 10, "A3": 50 },
			"formula": "=RANK(30, A1:A3, 1)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "CORREL perfect positive",
			"setup": { "A1": 1, "A2": 2, "A3": 3, "B1": 2, "B2": 4, "B3": 6 },
			"formula": "=CORREL(A1:A3, B1:B3)",
			"expected": { "kind": "number", "value": 1 }
		}
	]
}
