{
	"function": "date",
	"cases": [
		{
			"description": "DATE(2024,1,15) returns serial number",
			"setup": {},
			"formula": "DATE(2024, 1, 15)",
			"expected": { "kind": "number", "value": 45306 }
		},
		{
			"description": "YEAR extracts year from serial",
			"setup": { "A1": 45306 },
			"formula": "YEAR(A1)",
			"expected": { "kind": "number", "value": 2024 }
		},
		{
			"description": "MONTH extracts month",
			"setup": { "A1": 45306 },
			"formula": "MONTH(A1)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "DAY extracts day",
			"setup": { "A1": 45306 },
			"formula": "DAY(A1)",
			"expected": { "kind": "number", "value": 15 }
		},
		{
			"description": "EDATE adds months",
			"setup": { "A1": 45306 },
			"formula": "EDATE(A1, 3)",
			"expected": { "kind": "number", "value": 45397 }
		},
		{
			"description": "1900 leap year bug: DATE(1900,2,29) works",
			"setup": {},
			"formula": "DATE(1900, 2, 29)",
			"expected": { "kind": "number", "value": 61 }
		},
		{
			"description": "DATEVALUE parses ISO text for a fake settlement date",
			"setup": {},
			"formula": "DATEVALUE(\"2024-01-15\")",
			"expected": { "kind": "number", "value": 45306 }
		},
		{
			"description": "DATEDIF returns leftover days between billing checkpoints",
			"setup": {},
			"formula": "DATEDIF(DATE(2024, 1, 15), DATE(2024, 3, 20), \"MD\")",
			"expected": { "kind": "number", "value": 5 }
		},
		{
			"description": "EOMONTH returns month end for a reporting period",
			"setup": { "A1": 45306 },
			"formula": "EOMONTH(A1, 0)",
			"expected": { "kind": "number", "value": 45322 }
		},
		{
			"description": "WEEKDAY with return type 2 makes Monday equal 1",
			"setup": { "A1": 45306 },
			"formula": "WEEKDAY(A1, 2)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "WEEKNUM reports the third week for mid-January 2024",
			"setup": { "A1": 45306 },
			"formula": "WEEKNUM(A1)",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "NETWORKDAYS excludes a listed holiday from a finance work window",
			"setup": { "A1": 45306, "A2": 45310, "C1": 45308 },
			"formula": "NETWORKDAYS(A1, A2, C1:C1)",
			"expected": { "kind": "number", "value": 4 }
		},
		{
			"description": "WORKDAY skips weekends and one listed holiday",
			"setup": { "A1": 45306, "A2": 3, "C1": 45308 },
			"formula": "WORKDAY(A1, A2, C1:C1)",
			"expected": { "kind": "number", "value": 45310 }
		},
		{
			"description": "HOUR extracts noon from a half-day serial fraction",
			"setup": { "A1": 0.5 },
			"formula": "HOUR(A1)",
			"expected": { "kind": "number", "value": 12 }
		},
		{
			"description": "MINUTE extracts 15 minutes from a serial fraction",
			"setup": { "A1": 1.0104166666666667 },
			"formula": "MINUTE(A1)",
			"expected": { "kind": "number", "value": 15 }
		},
		{
			"description": "SECOND extracts 45 seconds from a serial fraction",
			"setup": { "A1": 1.0005208333333333 },
			"formula": "SECOND(A1)",
			"expected": { "kind": "number", "value": 45 }
		},
		{
			"description": "TIME builds a fraction for a fake 1:30 PM tipoff",
			"setup": {},
			"formula": "TIME(13, 30, 0)",
			"expected": { "kind": "number", "value": 0.5625 }
		},
		{
			"description": "TIMEVALUE parses a text timestamp",
			"setup": {},
			"formula": "TIMEVALUE(\"1:30 PM\")",
			"expected": { "kind": "number", "value": 0.5625 }
		},
		{
			"description": "DATE uses the 1904 system when requested",
			"setup": {},
			"context": { "dateSystem": "1904" },
			"formula": "DATE(1904, 1, 2)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "YEAR interprets serial 0 in the 1904 system",
			"setup": { "A1": 0 },
			"context": { "dateSystem": "1904" },
			"formula": "YEAR(A1)",
			"expected": { "kind": "number", "value": 1904 }
		},
		{
			"description": "DATEVALUE respects the 1904 system for imported text dates",
			"setup": {},
			"context": { "dateSystem": "1904" },
			"formula": "DATEVALUE(\"1904-01-02\")",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "DAYS360 returns days between dates on 360-day year (US method)",
			"setup": {},
			"formula": "DAYS360(DATE(2011, 1, 1), DATE(2011, 12, 31))",
			"expected": { "kind": "number", "value": 360 }
		},
		{
			"description": "DAYS360 US method: 1/30 to 2/1 gives 1 day",
			"setup": {},
			"formula": "DAYS360(DATE(2011, 1, 30), DATE(2011, 2, 1))",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "YEARFRAC basis 0 returns fraction for 1/1 to 7/30 2012",
			"setup": {},
			"formula": "YEARFRAC(DATE(2012, 1, 1), DATE(2012, 7, 30))",
			"expected": { "kind": "number", "approx": 0.58055556, "tolerance": 1e-6 }
		},
		{
			"description": "YEARFRAC basis 1 (actual/actual) for leap year",
			"setup": {},
			"formula": "YEARFRAC(DATE(2012, 1, 1), DATE(2012, 7, 30), 1)",
			"expected": { "kind": "number", "approx": 0.57650273, "tolerance": 1e-6 }
		},
		{
			"description": "YEARFRAC basis 3 (actual/365)",
			"setup": {},
			"formula": "YEARFRAC(DATE(2012, 1, 1), DATE(2012, 7, 30), 3)",
			"expected": { "kind": "number", "approx": 0.57808219, "tolerance": 1e-6 }
		}
	]
}
