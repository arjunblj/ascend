{
	"function": "engineering",
	"cases": [
		{
			"description": "BIN2DEC positive binary",
			"setup": {},
			"formula": "BIN2DEC(\"1010\")",
			"expected": { "kind": "number", "value": 10 }
		},
		{
			"description": "BIN2DEC negative two's complement",
			"setup": {},
			"formula": "BIN2DEC(\"1111111111\")",
			"expected": { "kind": "number", "value": -1 }
		},
		{
			"description": "BIN2DEC invalid returns #NUM!",
			"setup": {},
			"formula": "BIN2DEC(\"102\")",
			"expected": { "kind": "error", "value": "#NUM!" }
		},
		{
			"description": "DEC2BIN positive",
			"setup": {},
			"formula": "DEC2BIN(10)",
			"expected": { "kind": "string", "value": "1010" }
		},
		{
			"description": "DEC2BIN with places",
			"setup": {},
			"formula": "DEC2BIN(5, 8)",
			"expected": { "kind": "string", "value": "00000101" }
		},
		{
			"description": "DEC2BIN out of range returns #NUM!",
			"setup": {},
			"formula": "DEC2BIN(600)",
			"expected": { "kind": "error", "value": "#NUM!" }
		},
		{
			"description": "HEX2DEC positive",
			"setup": {},
			"formula": "HEX2DEC(\"FF\")",
			"expected": { "kind": "number", "value": 255 }
		},
		{
			"description": "HEX2DEC negative",
			"setup": {},
			"formula": "HEX2DEC(\"FFFFFFFFFF\")",
			"expected": { "kind": "number", "value": -1 }
		},
		{
			"description": "DEC2HEX positive",
			"setup": {},
			"formula": "DEC2HEX(255)",
			"expected": { "kind": "string", "value": "FF" }
		},
		{
			"description": "DEC2HEX with places",
			"setup": {},
			"formula": "DEC2HEX(15, 4)",
			"expected": { "kind": "string", "value": "000F" }
		},
		{
			"description": "OCT2DEC positive",
			"setup": {},
			"formula": "OCT2DEC(\"77\")",
			"expected": { "kind": "number", "value": 63 }
		},
		{
			"description": "OCT2DEC invalid returns #NUM!",
			"setup": {},
			"formula": "OCT2DEC(\"89\")",
			"expected": { "kind": "error", "value": "#NUM!" }
		},
		{
			"description": "DEC2OCT positive",
			"setup": {},
			"formula": "DEC2OCT(63)",
			"expected": { "kind": "string", "value": "77" }
		},
		{
			"description": "DEC2OCT with places",
			"setup": {},
			"formula": "DEC2OCT(8, 4)",
			"expected": { "kind": "string", "value": "0010" }
		},
		{
			"description": "BIN2HEX via decimal",
			"setup": {},
			"formula": "BIN2HEX(\"1111\")",
			"expected": { "kind": "string", "value": "F" }
		},
		{
			"description": "BIN2OCT via decimal",
			"setup": {},
			"formula": "BIN2OCT(\"111\")",
			"expected": { "kind": "string", "value": "7" }
		},
		{
			"description": "HEX2BIN via decimal",
			"setup": {},
			"formula": "HEX2BIN(\"A\")",
			"expected": { "kind": "string", "value": "1010" }
		},
		{
			"description": "HEX2OCT via decimal",
			"setup": {},
			"formula": "HEX2OCT(\"F\")",
			"expected": { "kind": "string", "value": "17" }
		},
		{
			"description": "OCT2BIN via decimal",
			"setup": {},
			"formula": "OCT2BIN(\"7\")",
			"expected": { "kind": "string", "value": "111" }
		},
		{
			"description": "OCT2HEX via decimal",
			"setup": {},
			"formula": "OCT2HEX(\"17\")",
			"expected": { "kind": "string", "value": "F" }
		},
		{
			"description": "DELTA equal returns 1",
			"setup": {},
			"formula": "DELTA(5, 5)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "DELTA not equal returns 0",
			"setup": {},
			"formula": "DELTA(5, 3)",
			"expected": { "kind": "number", "value": 0 }
		},
		{
			"description": "DELTA default second arg 0",
			"setup": {},
			"formula": "DELTA(0)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "GESTEP num >= step returns 1",
			"setup": {},
			"formula": "GESTEP(5, 3)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "GESTEP num < step returns 0",
			"setup": {},
			"formula": "GESTEP(2, 5)",
			"expected": { "kind": "number", "value": 0 }
		},
		{
			"description": "GESTEP default step 0",
			"setup": {},
			"formula": "GESTEP(1)",
			"expected": { "kind": "number", "value": 1 }
		}
	]
}
