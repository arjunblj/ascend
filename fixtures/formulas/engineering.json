		},
		{
			"description": "COMPLEX with zero imaginary",
			"setup": {},
			"formula": "COMPLEX(5,0)",
			"expected": { "kind": "string", "value": "5" }
		},
		{
			"description": "IMABS of 3+4i is 5",
			"setup": {},
			"formula": "IMABS(\"3+4i\")",
			"expected": { "kind": "number", "value": 5 }
		},
		{
			"description": "IMABS of real number",
			"setup": {},
			"formula": "IMABS(\"-5\")",
			"expected": { "kind": "number", "value": 5 }
		},
		{
			"description": "IMREAL extracts real part of complex number",
			"setup": {},
			"formula": "IMREAL(\"3+4i\")",
