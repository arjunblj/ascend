{
	"function": "engineering",
	"cases": [
		{
			"description": "BIN2DEC positive binary",
			"setup": {},
			"formula": "BIN2DEC(\"1010\")",
			"expected": { "kind": "number", "value": 10 }
		},
		{
			"description": "BIN2DEC negative two's complement",
			"setup": {},
			"formula": "BIN2DEC(\"1111111111\")",
			"expected": { "kind": "number", "value": -1 }
		},
		{
			"description": "BIN2DEC invalid returns #NUM!",
			"setup": {},
			"formula": "BIN2DEC(\"102\")",
			"expected": { "kind": "error", "value": "#NUM!" }
		},
		{
			"description": "DEC2BIN positive",
			"setup": {},
			"formula": "DEC2BIN(10)",
			"expected": { "kind": "string", "value": "1010" }
		},
		{
			"description": "DEC2BIN with places",
			"setup": {},
			"formula": "DEC2BIN(5, 8)",
			"expected": { "kind": "string", "value": "00000101" }
		},
		{
			"description": "DEC2BIN out of range returns #NUM!",
