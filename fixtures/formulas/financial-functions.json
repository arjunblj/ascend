{
	"function": "financial",
	"cases": [
		{
			"description": "PMT returns monthly payment for a 30-year mortgage at 6%",
			"setup": {},
			"formula": "PMT(0.06/12, 360, 200000)",
			"expected": { "kind": "number", "approx": -1199.101050305518, "tolerance": 1e-8 }
		},
		{
			"description": "PMT returns simple installment when rate is zero",
			"setup": {},
			"formula": "PMT(0, 12, 12000)",
			"expected": { "kind": "number", "value": -1000 }
		},
		{
			"description": "FV returns future value of monthly savings at 8% annual",
			"setup": {},
			"formula": "FV(0.08/12, 120, -500)",
			"expected": { "kind": "number", "approx": 91473.01759085356, "tolerance": 1e-6 }
		},
		{
			"description": "PV returns present value of an annuity",
			"setup": {},
			"formula": "PV(0.05/12, 60, -500)",
			"expected": { "kind": "number", "approx": 26495.35316196374, "tolerance": 1e-6 }
		},
		{
			"description": "NPER returns number of periods to pay off a loan",
			"setup": {},
			"formula": "NPER(0.06/12, -1000, 50000)",
			"expected": { "kind": "number", "approx": 57.68013595777633, "tolerance": 1e-8 }
		},
		{
			"description": "RATE solves for monthly interest given payment and principal",
			"setup": {},
			"formula": "RATE(60, -500, 25000)",
			"expected": { "kind": "number", "approx": 0.006183413161254274, "tolerance": 1e-8 }
		},
		{
			"description": "NPV returns net present value of uneven cash flows",
			"setup": { "A1": -10000, "A2": 3000, "A3": 4200, "A4": 6800 },
			"formula": "NPV(0.1, A1:A4)",
			"expected": { "kind": "number", "approx": 1188.4434123352216, "tolerance": 1e-8 }
		},
		{
			"description": "IRR returns internal rate of return for typical cash flows",
			"setup": { "A1": -10000, "A2": 5000, "A3": 4000, "A4": 3000 },
			"formula": "IRR(A1:A4)",
			"expected": { "kind": "number", "approx": 0.10651681242940653, "tolerance": 1e-8 }
		},
		{
			"description": "IPMT returns interest portion of 1st payment on a 5-year loan",
			"setup": {},
			"formula": "IPMT(0.05/12, 1, 60, 25000)",
			"expected": { "kind": "number", "approx": -104.16666666666667, "tolerance": 1e-8 }
		},
		{
			"description": "PPMT returns principal portion of 1st payment on a 5-year loan",
			"setup": {},
			"formula": "PPMT(0.05/12, 1, 60, 25000)",
			"expected": { "kind": "number", "approx": -367.61417443360517, "tolerance": 1e-8 }
		},
		{
			"description": "IPMT returns #NUM! when period is out of range",
			"setup": {},
			"formula": "IPMT(0.05/12, 0, 60, 25000)",
			"expected": { "kind": "error", "value": "#NUM!" }
		},
		{
			"description": "PMT with beginning-of-period payments reduces monthly amount",
			"setup": {},
			"formula": "PMT(0.06/12, 360, 200000, 0, 1)",
			"expected": { "kind": "number", "approx": -1193.1353734383263, "tolerance": 1e-8 }
		},
		{
			"description": "SLN returns straight-line depreciation",
			"setup": {},
			"formula": "SLN(10000, 1000, 9)",
			"expected": { "kind": "number", "approx": 1000, "tolerance": 1e-10 }
		},
		{
			"description": "SYD returns sum-of-years-digits depreciation for period 1",
			"setup": {},
			"formula": "SYD(10000, 1000, 5, 1)",
			"expected": { "kind": "number", "approx": 3000, "tolerance": 1e-10 }
		},
		{
			"description": "DDB returns double-declining balance for first period",
			"setup": {},
			"formula": "DDB(2400, 300, 10, 1)",
			"expected": { "kind": "number", "approx": 480, "tolerance": 1e-8 }
		},
		{
			"description": "DOLLARDE converts fractional dollar to decimal",
			"setup": {},
			"formula": "DOLLARDE(1.03, 32)",
			"expected": { "kind": "number", "approx": 1.09375, "tolerance": 1e-10 }
		},
		{
			"description": "DOLLARFR converts decimal to fractional dollar",
			"setup": {},
			"formula": "DOLLARFR(1.125, 16)",
			"expected": { "kind": "number", "approx": 1.02, "tolerance": 1e-10 }
		},
		{
			"description": "IRR with all same-sign cash flows returns #NUM!",
			"setup": { "A1": 100, "A2": 200, "A3": 300 },
			"formula": "IRR(A1:A3)",
			"expected": { "kind": "error", "value": "#NUM!" }
		},
		{
			"description": "XNPV with serial dates returns positive NPV for typical cash flows",
			"setup": {
				"A1": -10000,
				"A2": 3000,
				"A3": 4200,
				"A4": 6800,
				"B1": 43831,
				"B2": 43982,
				"B3": 44165,
				"B4": 44348
			},
			"formula": "XNPV(0.1,A1:A4,B1:B4)",
			"expected": { "kind": "number", "approx": 2674.49, "tolerance": 1 }
		},
		{
			"description": "IRR with single sign change converges",
			"setup": { "A1": -100, "A2": 110 },
			"formula": "IRR(A1:A2)",
			"expected": { "kind": "number", "approx": 0.1, "tolerance": 0.001 }
		},
		{
			"description": "IRR with guess parameter when default may not converge",
			"setup": { "A1": -70000, "A2": 12000, "A3": 15000, "A4": 18000, "A5": 21000 },
			"formula": "IRR(A1:A5, 0.1)",
			"expected": { "kind": "number", "approx": -0.021, "tolerance": 0.01 }
		},
		{
			"description": "XNPV with serial date values",
			"setup": {
				"A1": -1000,
				"A2": 500,
				"A3": 600,
				"B1": 44927,
				"B2": 44988,
				"B3": 45048
			},
			"formula": "XNPV(0.1,A1:A3,B1:B3)",
			"expected": { "kind": "number", "approx": 73.44, "tolerance": 1 }
		}
	]
}
