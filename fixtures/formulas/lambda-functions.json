{
	"function": "lambda",
	"cases": [
		{
			"description": "LET binds single variable and evaluates body",
			"setup": {},
			"formula": "LET(x, 5, x+1)",
			"expected": { "kind": "number", "value": 6 }
		},
		{
			"description": "LET binds two variables and multiplies them",
			"setup": {},
			"formula": "LET(a, 2, b, 3, a*b)",
			"expected": { "kind": "number", "value": 6 }
		},
		{
			"description": "LET nested binding uses outer variable",
			"setup": {},
			"formula": "LET(x, 10, LET(y, 20, x+y))",
			"expected": { "kind": "number", "value": 30 }
		},
		{
			"description": "LET with cell reference in binding",
			"setup": { "A1": 7 },
			"formula": "LET(val, A1*2, val+3)",
			"expected": { "kind": "number", "value": 17 }
		},
		{
			"description": "LET binding reused multiple times in body",
			"setup": {},
			"formula": "LET(x, 3, x*x + x)",
			"expected": { "kind": "number", "value": 12 }
		},
		{
			"description": "LET with string binding passed to UPPER",
			"setup": {},
			"formula": "LET(s, \"hello\", UPPER(s))",
			"expected": { "kind": "string", "value": "HELLO" }
		},
		{
			"description": "LET three bindings with compound expression",
			"setup": {},
			"formula": "LET(a, 2, b, 3, c, 5, a+b*c)",
			"expected": { "kind": "number", "value": 17 }
		},
		{
			"description": "LET with SUM over range binding",
			"setup": { "A1": 10, "A2": 20, "A3": 30 },
			"formula": "LET(total, SUM(A1:A3), total/3)",
			"expected": { "kind": "number", "value": 20 }
		},
		{
			"description": "LAMBDA single parameter invocation",
			"setup": {},
			"formula": "LAMBDA(x, x+1)(5)",
			"expected": { "kind": "number", "value": 6 }
		},
		{
			"description": "LAMBDA two parameter invocation returns sum",
			"setup": {},
			"formula": "LAMBDA(x, y, x+y)(3, 4)",
			"expected": { "kind": "number", "value": 7 }
		},
		{
			"description": "LAMBDA with multiplication body",
			"setup": {},
			"formula": "LAMBDA(a, b, a*b)(6, 7)",
			"expected": { "kind": "number", "value": 42 }
		},
		{
			"description": "Standalone LAMBDA without invocation returns #CALC!",
			"setup": {},
			"formula": "LAMBDA(x, x+1)",
			"expected": { "kind": "error", "value": "#CALC!" }
		},
		{
			"description": "LET-bound LAMBDA invoked in body",
			"setup": {},
			"formula": "LET(f, LAMBDA(x, x*2), f(5))",
			"expected": { "kind": "number", "value": 10 }
		},
		{
			"description": "LET-bound LAMBDA with two parameters",
			"setup": {},
			"formula": "LET(add, LAMBDA(a, b, a+b), add(10, 20))",
			"expected": { "kind": "number", "value": 30 }
		},
		{
			"description": "MAP doubles each value, anchor holds first result",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "MAP(A1:A3, LAMBDA(x, x*2))",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "MAP second element verified via INDEX",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "INDEX(MAP(A1:A3, LAMBDA(x, x*2)), 2)",
			"expected": { "kind": "number", "value": 4 }
		},
		{
			"description": "MAP third element verified via INDEX",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "INDEX(MAP(A1:A3, LAMBDA(x, x*2)), 3)",
			"expected": { "kind": "number", "value": 6 }
		},
		{
			"description": "MAP with addition, anchor holds first result",
			"setup": { "A1": 10, "A2": 20, "A3": 30 },
			"formula": "MAP(A1:A3, LAMBDA(v, v+5))",
			"expected": { "kind": "number", "value": 15 }
		},
		{
			"description": "REDUCE accumulates sum starting from zero",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "REDUCE(0, A1:A3, LAMBDA(a, b, a+b))",
			"expected": { "kind": "number", "value": 6 }
		},
		{
			"description": "REDUCE accumulates product starting from one",
			"setup": { "A1": 2, "A2": 3, "A3": 4 },
			"formula": "REDUCE(1, A1:A3, LAMBDA(a, b, a*b))",
			"expected": { "kind": "number", "value": 24 }
		},
		{
			"description": "REDUCE with non-zero initial accumulator",
			"setup": { "A1": 10, "A2": 20 },
			"formula": "REDUCE(100, A1:A2, LAMBDA(a, b, a+b))",
			"expected": { "kind": "number", "value": 130 }
		},
		{
			"description": "REDUCE finds maximum in range",
			"setup": { "A1": 3, "A2": 7, "A3": 2, "A4": 9, "A5": 1 },
			"formula": "REDUCE(0, A1:A5, LAMBDA(a, b, IF(b>a, b, a)))",
			"expected": { "kind": "number", "value": 9 }
		},
		{
			"description": "REDUCE concatenates strings",
			"setup": { "A1": "a", "A2": "b", "A3": "c" },
			"formula": "REDUCE(\"\", A1:A3, LAMBDA(a, b, a&b))",
			"expected": { "kind": "string", "value": "abc" }
		},
		{
			"description": "SCAN running sum, anchor holds first accumulated value",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "SCAN(0, A1:A3, LAMBDA(a, b, a+b))",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "SCAN running sum, second element via INDEX",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "INDEX(SCAN(0, A1:A3, LAMBDA(a, b, a+b)), 2)",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "SCAN running sum, third element via INDEX",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "INDEX(SCAN(0, A1:A3, LAMBDA(a, b, a+b)), 3)",
			"expected": { "kind": "number", "value": 6 }
		},
		{
			"description": "SCAN running product, anchor holds first accumulated value",
			"setup": { "A1": 2, "A2": 3, "A3": 4 },
			"formula": "SCAN(1, A1:A3, LAMBDA(a, b, a*b))",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "SCAN running product, third element via INDEX",
			"setup": { "A1": 2, "A2": 3, "A3": 4 },
			"formula": "INDEX(SCAN(1, A1:A3, LAMBDA(a, b, a*b)), 3)",
			"expected": { "kind": "number", "value": 24 }
		},
		{
			"description": "BYROW with SUM, anchor holds first row sum",
			"setup": { "A1": 1, "B1": 2, "A2": 3, "B2": 4, "A3": 5, "B3": 6 },
			"formula": "BYROW(A1:B3, LAMBDA(r, SUM(r)))",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "BYROW with SUM, second row via INDEX",
			"setup": { "A1": 1, "B1": 2, "A2": 3, "B2": 4, "A3": 5, "B3": 6 },
			"formula": "INDEX(BYROW(A1:B3, LAMBDA(r, SUM(r))), 2)",
			"expected": { "kind": "number", "value": 7 }
		},
		{
			"description": "BYROW with SUM, third row via INDEX",
			"setup": { "A1": 1, "B1": 2, "A2": 3, "B2": 4, "A3": 5, "B3": 6 },
			"formula": "INDEX(BYROW(A1:B3, LAMBDA(r, SUM(r))), 3)",
			"expected": { "kind": "number", "value": 11 }
		},
		{
			"description": "BYROW with MAX per row, anchor holds first row max",
			"setup": { "A1": 5, "B1": 2, "A2": 3, "B2": 8 },
			"formula": "BYROW(A1:B2, LAMBDA(r, MAX(r)))",
			"expected": { "kind": "number", "value": 5 }
		},
		{
			"description": "BYCOL with SUM, anchor holds first column sum",
			"setup": { "A1": 1, "B1": 2, "A2": 3, "B2": 4, "A3": 5, "B3": 6 },
			"formula": "BYCOL(A1:B3, LAMBDA(c, SUM(c)))",
			"expected": { "kind": "number", "value": 9 }
		},
		{
			"description": "BYCOL with SUM, second column via INDEX",
			"setup": { "A1": 1, "B1": 2, "A2": 3, "B2": 4, "A3": 5, "B3": 6 },
			"formula": "INDEX(BYCOL(A1:B3, LAMBDA(c, SUM(c))), 2)",
			"expected": { "kind": "number", "value": 12 }
		},
		{
			"description": "BYCOL with AVERAGE, anchor holds first column average",
			"setup": { "A1": 10, "B1": 20, "A2": 30, "B2": 40 },
			"formula": "BYCOL(A1:B2, LAMBDA(c, AVERAGE(c)))",
			"expected": { "kind": "number", "value": 20 }
		},
		{
			"description": "MAKEARRAY multiplication table, anchor holds (1,1)=1",
			"setup": {},
			"formula": "MAKEARRAY(2, 3, LAMBDA(r, c, r*c))",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "MAKEARRAY multiplication table, (1,3) via INDEX is 3",
			"setup": {},
			"formula": "INDEX(MAKEARRAY(2, 3, LAMBDA(r, c, r*c)), 1, 3)",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "MAKEARRAY multiplication table, (2,2) via INDEX is 4",
			"setup": {},
			"formula": "INDEX(MAKEARRAY(2, 3, LAMBDA(r, c, r*c)), 2, 2)",
			"expected": { "kind": "number", "value": 4 }
		},
		{
			"description": "MAKEARRAY multiplication table, (2,3) via INDEX is 6",
			"setup": {},
			"formula": "INDEX(MAKEARRAY(2, 3, LAMBDA(r, c, r*c)), 2, 3)",
			"expected": { "kind": "number", "value": 6 }
		},
		{
			"description": "MAKEARRAY addition table, anchor holds (1,1)=2",
			"setup": {},
			"formula": "MAKEARRAY(3, 3, LAMBDA(r, c, r+c))",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "MAKEARRAY constant fill returns 42 at anchor",
			"setup": {},
			"formula": "MAKEARRAY(2, 2, LAMBDA(r, c, 42))",
			"expected": { "kind": "number", "value": 42 }
		}
	]
}
