{
	"function": "lookup",
	"cases": [
		{
			"description": "VLOOKUP exact match",
			"setup": {
				"A1": "apple",
				"A2": "banana",
				"A3": "cherry",
				"B1": 10,
				"B2": 20,
				"B3": 30
			},
			"formula": "VLOOKUP(\"banana\", A1:B3, 2, FALSE)",
			"expected": { "kind": "number", "value": 20 }
		},
		{
			"description": "VLOOKUP not found returns #N/A",
			"setup": {
				"A1": "apple",
				"A2": 10
			},
			"formula": "VLOOKUP(\"xyz\", A1:A2, 1, FALSE)",
			"expected": { "kind": "error", "value": "#N/A" }
		},
		{
			"description": "INDEX returns value at row,col",
			"setup": {
				"A1": 1,
				"A2": 2,
				"B1": 3,
				"B2": 4
			},
			"formula": "INDEX(A1:B2, 2, 2)",
			"expected": { "kind": "number", "value": 4 }
		},
		{
			"description": "MATCH finds position",
			"setup": {
				"A1": "a",
				"A2": "b",
				"A3": "c"
			},
			"formula": "MATCH(\"b\", A1:A3, 0)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "INDEX/MATCH pattern",
			"setup": {
				"A1": "Jan",
				"A2": "Feb",
				"A3": "Mar",
				"B1": 100,
				"B2": 200,
				"B3": 300
			},
			"formula": "INDEX(B1:B3, MATCH(\"Feb\", A1:A3, 0))",
			"expected": { "kind": "number", "value": 200 }
		},
		{
			"description": "CHOOSE returns nth argument",
			"setup": { "A1": 2 },
			"formula": "CHOOSE(A1, \"First\", \"Second\", \"Third\")",
			"expected": { "kind": "string", "value": "Second" }
		},
		{
			"description": "CHOOSE with numbers",
			"setup": { "A1": 3 },
			"formula": "CHOOSE(A1, 10, 20, 30, 40)",
			"expected": { "kind": "number", "value": 30 }
		},
		{
			"description": "VLOOKUP approximate match",
			"setup": {
				"A1": 10,
				"A2": 20,
				"A3": 30,
				"B1": "small",
				"B2": "medium",
				"B3": "large"
			},
			"formula": "VLOOKUP(25, A1:B3, 2, TRUE)",
			"expected": { "kind": "string", "value": "medium" }
		},
		{
			"description": "HLOOKUP exact match across the header row",
			"setup": {
				"A1": "Jan",
				"B1": "Feb",
				"C1": "Mar",
				"A2": 10,
				"B2": 20,
				"C2": 30
			},
			"formula": "HLOOKUP(\"Mar\", A1:C2, 2, FALSE)",
			"expected": { "kind": "number", "value": 30 }
		},
		{
			"description": "ROWS returns the row dimension of a small stats range",
			"setup": {
				"A1": 1,
				"B1": 2,
				"C1": 3,
				"A2": 4,
				"B2": 5,
				"C2": 6
			},
			"formula": "ROWS(A1:C2)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "COLUMNS returns the column dimension of a small stats range",
			"setup": {
				"A1": 1,
				"B1": 2,
				"C1": 3,
				"A2": 4,
				"B2": 5,
				"C2": 6
			},
			"formula": "COLUMNS(A1:C2)",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "MATCH supports wildcard matching in text lookups",
			"setup": {
				"A1": "North-East",
				"A2": "South",
				"A3": "North-West"
			},
			"formula": "MATCH(\"North*\", A1:A3, 0)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "LOOKUP returns the last matching fee band",
			"setup": {
				"A1": 10,
				"A2": 20,
				"A3": 30,
				"B1": "small",
				"B2": "medium",
				"B3": "large"
			},
			"formula": "LOOKUP(25, A1:A3, B1:B3)",
			"expected": { "kind": "string", "value": "medium" }
		},
		{
			"description": "ADDRESS returns an absolute A1 reference",
			"setup": {},
			"formula": "ADDRESS(2, 3)",
			"expected": { "kind": "string", "value": "$C$2" }
		},
		{
			"description": "ADDRESS can prefix a sheet name",
			"setup": {},
			"formula": "ADDRESS(4, 2, 1, TRUE, \"Stats\")",
			"expected": { "kind": "string", "value": "'Stats'!$B$4" }
		},
		{
			"description": "ROW returns the current row when called without arguments",
			"setup": {},
			"formula": "ROW()",
			"expected": { "kind": "number", "value": 11 }
		},
		{
			"description": "ROW returns the first row of a referenced range",
			"setup": { "B7": 42 },
			"formula": "ROW(B7)",
			"expected": { "kind": "number", "value": 7 }
		},
		{
			"description": "COLUMN returns the current column when called without arguments",
			"setup": {},
			"formula": "COLUMN()",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "COLUMN returns the first column of a referenced range",
			"setup": { "AA3": 9 },
			"formula": "COLUMN(AA3)",
			"expected": { "kind": "number", "value": 27 }
		},
		{
			"description": "INDIRECT resolves a cell reference from text",
			"setup": { "A1": 42 },
			"formula": "INDIRECT(\"A1\")",
			"expected": { "kind": "number", "value": 42 }
		},
		{
			"description": "INDIRECT resolves a range reference via SUM",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "SUM(INDIRECT(\"A1:A3\"))",
			"expected": { "kind": "number", "value": 6 }
		},
		{
			"description": "INDIRECT with R1C1 style resolves a cell reference",
			"setup": { "A1": 99 },
			"formula": "INDIRECT(\"R1C1\", FALSE)",
			"expected": { "kind": "number", "value": 99 }
		},
		{
			"description": "INDIRECT with empty string returns #REF!",
			"setup": {},
			"formula": "INDIRECT(\"\")",
			"expected": { "kind": "error", "value": "#REF!" }
		},
		{
			"description": "OFFSET moves reference down by one row",
			"setup": { "A1": 10, "A2": 20 },
			"formula": "OFFSET(A1, 1, 0)",
			"expected": { "kind": "number", "value": 20 }
		},
		{
			"description": "OFFSET moves reference right by one column",
			"setup": { "A1": 10, "B1": 30 },
			"formula": "OFFSET(A1, 0, 1)",
			"expected": { "kind": "number", "value": 30 }
		},
		{
			"description": "OFFSET with height and width returns a range for SUM",
			"setup": { "B2": 1, "B3": 2, "C2": 3, "C3": 4 },
			"formula": "SUM(OFFSET(A1, 1, 1, 2, 2))",
			"expected": { "kind": "number", "value": 10 }
		},
		{
			"description": "OFFSET with negative row offset",
			"setup": { "A3": 33, "A5": 55 },
			"formula": "OFFSET(A5, -2, 0)",
			"expected": { "kind": "number", "value": 33 }
		},
		{
			"description": "OFFSET out of bounds returns #REF!",
			"setup": { "A1": 1 },
			"formula": "OFFSET(A1, -1, 0)",
			"expected": { "kind": "error", "value": "#REF!" }
		},
		{
			"description": "FORMULATEXT returns formula text from a cell",
			"setup": {},
			"setupFormulas": { "B1": "1+2" },
			"formula": "FORMULATEXT(B1)",
			"expected": { "kind": "string", "value": "=1+2" }
		},
		{
			"description": "FORMULATEXT returns #N/A for a cell without a formula",
			"setup": { "A1": 42 },
			"formula": "FORMULATEXT(A1)",
			"expected": { "kind": "error", "value": "#N/A" }
		},
		{
			"description": "FORMULATEXT returns #N/A for an empty cell",
			"setup": {},
			"formula": "FORMULATEXT(C5)",
			"expected": { "kind": "error", "value": "#N/A" }
		}
	]
}
