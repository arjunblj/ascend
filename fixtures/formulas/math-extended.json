		{
			"description": "QUOTIENT integer division",
			"setup": {},
			"formula": "=QUOTIENT(7, 2)",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "QUOTIENT divisor zero returns #DIV/0!",
			"setup": {},
			"formula": "=QUOTIENT(5, 0)",
			"expected": { "kind": "error", "value": "#DIV/0!" }
		},
		{
			"description": "DEGREES radians to degrees",
			"setup": {},
			"formula": "=DEGREES(PI())",
			"expected": { "kind": "number", "approx": 180, "tolerance": 0.0001 }
		},
		{
			"description": "DEGREES half pi",
			"setup": {},
			"formula": "=DEGREES(PI()/2)",
			"expected": { "kind": "number", "approx": 90, "tolerance": 0.0001 }
		},
		{
			"description": "RADIANS degrees to radians",
			"setup": {},
			"formula": "=RADIANS(180)",
			"expected": { "kind": "number", "approx": 3.14159265, "tolerance": 0.0001 }
		},
		{
			"description": "RADIANS 90 degrees",
			"setup": {},
			"formula": "=RADIANS(90)",
			"expected": { "kind": "number", "approx": 1.5707963, "tolerance": 0.0001 }
		},
