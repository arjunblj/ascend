{
	"function": "MATH_EXTENDED",
	"description": "Extended math functions",
	"cases": [
		{
			"description": "TRUNC positive",
			"setup": {},
			"formula": "=TRUNC(4.7)",
			"expected": { "kind": "number", "value": 4 }
		},
		{
			"description": "TRUNC negative towards zero",
			"setup": {},
			"formula": "=TRUNC(-4.7)",
			"expected": { "kind": "number", "value": -4 }
		},
		{
			"description": "TRUNC with decimals",
			"setup": { "A1": 3.14159 },
			"formula": "=TRUNC(A1, 2)",
			"expected": { "kind": "number", "value": 3.14 }
		},
		{
			"description": "MROUND to nearest multiple",
			"setup": {},
			"formula": "=MROUND(10, 3)",
			"expected": { "kind": "number", "value": 9 }
		},
		{
			"description": "MROUND different signs returns #NUM!",
			"setup": {},
			"formula": "=MROUND(10, -3)",
			"expected": { "kind": "error", "value": "#NUM!" }
		},
		{
			"description": "GCD two numbers",
			"setup": {},
			"formula": "=GCD(24, 36)",
			"expected": { "kind": "number", "value": 12 }
		},
		{
			"description": "GCD multiple numbers",
			"setup": {},
			"formula": "=GCD(12, 18, 24)",
			"expected": { "kind": "number", "value": 6 }
		},
		{
			"description": "LCM two numbers",
			"setup": {},
			"formula": "=LCM(4, 6)",
			"expected": { "kind": "number", "value": 12 }
		},
		{
			"description": "LCM multiple numbers",
			"setup": {},
			"formula": "=LCM(2, 3, 4)",
			"expected": { "kind": "number", "value": 12 }
		},
		{
			"description": "FACT 5",
			"setup": {},
			"formula": "=FACT(5)",
			"expected": { "kind": "number", "value": 120 }
		},
		{
			"description": "FACT negative returns #NUM!",
			"setup": {},
			"formula": "=FACT(-1)",
			"expected": { "kind": "error", "value": "#NUM!" }
		},
		{
			"description": "FACTDOUBLE 7",
			"setup": {},
			"formula": "=FACTDOUBLE(7)",
			"expected": { "kind": "number", "value": 105 }
		},
		{
			"description": "FACTDOUBLE negative returns #NUM!",
			"setup": {},
			"formula": "=FACTDOUBLE(-2)",
			"expected": { "kind": "error", "value": "#NUM!" }
		},
		{
			"description": "COMBIN C(5,2)",
			"setup": {},
			"formula": "=COMBIN(5, 2)",
			"expected": { "kind": "number", "value": 10 }
		},
		{
			"description": "COMBIN k>n returns #NUM!",
			"setup": {},
			"formula": "=COMBIN(3, 5)",
			"expected": { "kind": "error", "value": "#NUM!" }
		},
		{
			"description": "PERMUT P(5,2)",
			"setup": {},
			"formula": "=PERMUT(5, 2)",
			"expected": { "kind": "number", "value": 20 }
		},
		{
			"description": "PERMUT k>n returns #NUM!",
			"setup": {},
			"formula": "=PERMUT(3, 5)",
			"expected": { "kind": "error", "value": "#NUM!" }
		},
		{
			"description": "RANDBETWEEN with seed",
			"setup": { "A1": 1, "A2": 10 },
			"formula": "=RANDBETWEEN(A1, A2)",
			"context": { "randomSeed": 42 },
			"expected": { "kind": "number", "value": 7 }
		},
		{
			"description": "RANDBETWEEN inclusive bounds",
			"setup": {},
			"formula": "=RANDBETWEEN(5, 5)",
			"context": { "randomSeed": 123 },
			"expected": { "kind": "number", "value": 5 }
		},
		{
			"description": "ODD positive",
			"setup": {},
			"formula": "=ODD(2)",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "ODD negative away from zero",
			"setup": {},
			"formula": "=ODD(-2)",
			"expected": { "kind": "number", "value": -3 }
		},
		{
			"description": "EVEN positive",
			"setup": {},
			"formula": "=EVEN(1)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "EVEN negative",
			"setup": {},
			"formula": "=EVEN(-1)",
			"expected": { "kind": "number", "value": -2 }
