{
	"function": "math",
	"cases": [
		{
			"description": "SUM of a range",
			"setup": { "A1": 1, "A2": 2, "A3": 3, "A4": 4 },
			"formula": "SUM(A1:A4)",
			"expected": { "kind": "number", "value": 10 }
		},
		{
			"description": "AVERAGE of a range",
			"setup": { "A1": 10, "A2": 20, "A3": 30 },
			"formula": "AVERAGE(A1:A3)",
			"expected": { "kind": "number", "value": 20 }
		},
		{
			"description": "COUNT counts numbers and dates in range (ignores text, boolean)",
			"setup": { "A1": 1, "A2": "hello", "A3": 3, "A4": true },
			"formula": "COUNT(A1:A4)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "COUNTA counts non-empty cells",
			"setup": { "A1": 1, "A2": "hello", "A3": 3 },
			"formula": "COUNTA(A1:A3)",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "MIN of range",
			"setup": { "A1": 5, "A2": 2, "A3": 8 },
			"formula": "MIN(A1:A3)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "MAX of range",
			"setup": { "A1": 5, "A2": 2, "A3": 8 },
			"formula": "MAX(A1:A3)",
			"expected": { "kind": "number", "value": 8 }
		},
		{
			"description": "ROUND to 1 decimal",
			"setup": { "A1": 3.14159 },
			"formula": "ROUND(A1, 1)",
			"expected": { "kind": "number", "value": 3.1 }
		},
		{
			"description": "ROUNDUP",
			"setup": { "A1": 2.1 },
			"formula": "ROUNDUP(A1, 0)",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "ROUNDDOWN",
			"setup": { "A1": 2.9 },
			"formula": "ROUNDDOWN(A1, 0)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "ABS of negative",
			"setup": { "A1": -42 },
			"formula": "ABS(A1)",
			"expected": { "kind": "number", "value": 42 }
		},
		{
			"description": "MOD remainder",
			"setup": { "A1": 10, "A2": 3 },
			"formula": "MOD(A1, A2)",
			"expected": { "kind": "number", "value": 1 }
		}
	]
}
