{
	"function": "math",
	"cases": [
		{
			"description": "SUM of a range",
			"setup": { "A1": 1, "A2": 2, "A3": 3, "A4": 4 },
			"formula": "SUM(A1:A4)",
			"expected": { "kind": "number", "value": 10 }
		},
		{
			"description": "AVERAGE of a range",
			"setup": { "A1": 10, "A2": 20, "A3": 30 },
			"formula": "AVERAGE(A1:A3)",
			"expected": { "kind": "number", "value": 20 }
		},
		{
			"description": "COUNT counts numbers and dates in range (ignores text, boolean)",
			"setup": { "A1": 1, "A2": "hello", "A3": 3, "A4": true },
			"formula": "COUNT(A1:A4)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "COUNT counts numeric text and booleans supplied directly",
			"setup": {},
			"formula": "COUNT(\"1\", TRUE, \"nope\", \"\")",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "COUNTA counts non-empty cells",
			"setup": { "A1": 1, "A2": "hello", "A3": 3 },
			"formula": "COUNTA(A1:A3)",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "MIN of range",
			"setup": { "A1": 5, "A2": 2, "A3": 8 },
			"formula": "MIN(A1:A3)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "MAX of range",
			"setup": { "A1": 5, "A2": 2, "A3": 8 },
			"formula": "MAX(A1:A3)",
			"expected": { "kind": "number", "value": 8 }
		},
		{
			"description": "ROUND to 1 decimal",
			"setup": { "A1": 3.14159 },
			"formula": "ROUND(A1, 1)",
			"expected": { "kind": "number", "value": 3.1 }
		},
		{
			"description": "ROUNDUP",
			"setup": { "A1": 2.1 },
			"formula": "ROUNDUP(A1, 0)",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "ROUNDDOWN",
			"setup": { "A1": 2.9 },
			"formula": "ROUNDDOWN(A1, 0)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "ABS of negative",
			"setup": { "A1": -42 },
			"formula": "ABS(A1)",
			"expected": { "kind": "number", "value": 42 }
		},
		{
			"description": "MOD remainder",
			"setup": { "A1": 10, "A2": 3 },
			"formula": "MOD(A1, A2)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "SUMIFS totals settled east-region finance items",
			"setup": {
				"A1": 120,
				"A2": 80,
				"A3": 40,
				"A4": 30,
				"B1": "East",
				"B2": "West",
				"B3": "East",
				"B4": "East",
				"C1": "Settled",
				"C2": "Settled",
				"C3": "Open",
				"C4": "Settled"
			},
			"formula": "SUMIFS(A1:A4, B1:B4, \"East\", C1:C4, \"Settled\")",
			"expected": { "kind": "number", "value": 150 }
		},
		{
			"description": "SUMIF treats a one-cell sum range as the top-left of a criteria-shaped range",
			"setup": { "A1": "x", "A2": "y", "A3": "x", "B1": 10, "B2": 20, "B3": 30 },
			"formula": "SUMIF(A1:A3,\"x\",B1)",
			"expected": { "kind": "number", "value": 40 }
		},
		{
			"description": "AVERAGEIF treats a one-cell average range as the top-left of a criteria-shaped range",
			"setup": { "A1": "x", "A2": "y", "A3": "x", "B1": 10, "B2": 20, "B3": 30 },
			"formula": "AVERAGEIF(A1:A3,\"x\",B1)",
			"expected": { "kind": "number", "value": 20 }
		},
		{
			"description": "COUNTIFS counts athletes with 10+ points and an active flag",
			"setup": {
				"A1": 8,
				"A2": 12,
				"A3": 15,
				"A4": 9,
				"B1": true,
				"B2": false,
				"B3": true,
				"B4": true
			},
			"formula": "COUNTIFS(A1:A4, \">=10\", B1:B4, TRUE)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "COUNTIF supports wildcard criteria",
			"setup": {
				"A1": "North",
				"A2": "Northeast",
				"A3": "South",
				"A4": "Northwest"
			},
			"formula": "COUNTIF(A1:A4, \"North*\")",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "SUMIFS supports wildcard and nonblank criteria together",
			"setup": {
				"A1": 120,
				"A2": 40,
				"A3": 25,
				"A4": 60,
				"B1": "East",
				"B2": "East-Alt",
				"B3": "West",
				"B4": "East",
				"C1": "ok",
				"C2": "",
				"C4": "ok"
			},
			"formula": "SUMIFS(A1:A4, B1:B4, \"East*\", C1:C4, \"<>\")",
			"expected": { "kind": "number", "value": 180 }
		},
		{
			"description": "COUNTIF treats empty criteria as blank matching",
			"setup": {
				"A1": "",
				"A2": "value"
			},
			"formula": "COUNTIF(A1:A3, \"\")",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "COUNTIF treats <> with no operand as nonblank matching",
			"setup": {
				"A1": "",
				"A2": "value"
			},
			"formula": "COUNTIF(A1:A3, \"<>\")",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "AVERAGEIF returns #DIV/0! when no invoices match the threshold",
			"setup": { "A1": 100, "A2": 200, "A3": 300 },
			"formula": "AVERAGEIF(A1:A3, \">500\")",
			"expected": { "kind": "error", "value": "#DIV/0!" }
		},
		{
			"description": "COUNTBLANK counts missing cells and empty strings",
			"setup": { "A1": 1, "A3": "" },
			"formula": "COUNTBLANK(A1:A3)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "SUMPRODUCT computes weighted score from two 2x2 ranges",
			"setup": {
				"A1": 1,
				"B1": 3,
				"A2": 2,
				"B2": 4,
				"C1": 5,
				"D1": 7,
				"C2": 6,
				"D2": 8
			},
			"formula": "SUMPRODUCT(A1:B2, C1:D2)",
			"expected": { "kind": "number", "value": 70 }
		},
		{
			"description": "INT rounds negative values down",
			"setup": { "A1": -2.3 },
			"formula": "INT(A1)",
			"expected": { "kind": "number", "value": -3 }
		},
		{
			"description": "POWER raises a fake interest factor",
			"setup": { "A1": 1.05, "A2": 2 },
			"formula": "POWER(A1, A2)",
			"expected": { "kind": "number", "value": 1.1025 }
		},
		{
			"description": "SQRT computes square root of training load",
			"setup": { "A1": 81 },
			"formula": "SQRT(A1)",
			"expected": { "kind": "number", "value": 9 }
		},
		{
			"description": "LOG uses a custom base",
			"setup": { "A1": 8, "A2": 2 },
			"formula": "LOG(A1, A2)",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "CEILING rounds fees up to the next quarter unit",
			"setup": { "A1": 2.13, "A2": 0.25 },
			"formula": "CEILING(A1, A2)",
			"expected": { "kind": "number", "value": 2.25 }
		},
		{
			"description": "FLOOR rounds ticket totals down to the prior quarter unit",
			"setup": { "A1": 2.13, "A2": 0.25 },
			"formula": "FLOOR(A1, A2)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "MINIFS finds the fastest legal sprint time",
			"setup": {
				"A1": 11.2,
				"A2": 10.9,
				"A3": 11.4,
				"B1": "Legal",
				"B2": "Legal",
				"B3": "Wind"
			},
			"formula": "MINIFS(A1:A3, B1:B3, \"Legal\")",
			"expected": { "kind": "number", "value": 10.9 }
		},
		{
			"description": "MAXIFS finds the highest approved payout",
			"setup": {
				"A1": 240,
				"A2": 180,
				"A3": 300,
				"B1": "Approved",
				"B2": "Pending",
				"B3": "Approved"
			},
			"formula": "MAXIFS(A1:A3, B1:B3, \"Approved\")",
			"expected": { "kind": "number", "value": 300 }
		},
		{
			"description": "AVERAGEIFS averages rows matching two criteria",
			"setup": {
				"A1": 10,
				"A2": 20,
				"A3": 30,
				"A4": 40,
				"B1": "West",
				"B2": "West",
				"B3": "East",
				"B4": "West",
				"C1": "Open",
				"C2": "Closed",
				"C3": "Open",
				"C4": "Open"
			},
			"formula": "AVERAGEIFS(A1:A4, B1:B4, \"West\", C1:C4, \"Open\")",
			"expected": { "kind": "number", "value": 25 }
		},
		{
			"description": "CEILING.MATH rounds a positive decimal to the next multiple",
			"setup": {},
			"formula": "CEILING.MATH(6.3, 2)",
			"expected": { "kind": "number", "value": 8 }
		},
		{
			"description": "FLOOR.MATH rounds a positive decimal down to the prior multiple",
			"setup": {},
			"formula": "FLOOR.MATH(6.7, 2)",
			"expected": { "kind": "number", "value": 6 }
		},
		{
			"description": "PRODUCT multiplies numeric arguments",
			"setup": { "A1": 2, "A2": 3, "A3": 5 },
			"formula": "PRODUCT(A1:A3)",
			"expected": { "kind": "number", "value": 30 }
		},
		{
			"description": "EXP returns Euler exponential",
			"setup": {},
			"formula": "EXP(1)",
			"expected": { "kind": "number", "approx": 2.718281828459045, "tolerance": 1e-12 }
		},
		{
			"description": "LN returns natural logarithm",
			"setup": {},
			"formula": "LN(EXP(1))",
			"expected": { "kind": "number", "approx": 1, "tolerance": 1e-12 }
		},
		{
			"description": "LOG10 returns base-10 logarithm",
			"setup": {},
			"formula": "LOG10(1000)",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "SIGN classifies negative numbers",
			"setup": {},
			"formula": "SIGN(-42)",
			"expected": { "kind": "number", "value": -1 }
		},
		{
			"description": "ROMAN converts Arabic numerals to Roman text",
			"setup": {},
			"formula": "ROMAN(499)",
			"expected": { "kind": "string", "value": "CDXCIX" }
		},
		{
			"description": "RAND returns a unit-interval numeric value",
			"setup": {},
			"context": { "randomSeed": 42 },
			"formula": "AND(RAND()>=0,RAND()<1)",
			"expected": { "kind": "boolean", "value": true }
		},
		{
			"description": "SUBTOTAL sums a compact finance range",
			"setup": { "A1": 100, "A2": 200, "A3": 300 },
			"formula": "SUBTOTAL(9, A1:A3)",
			"expected": { "kind": "number", "value": 600 }
		},
		{
			"description": "SUBTOTAL averages a compact stats range",
			"setup": { "A1": 8, "A2": 10, "A3": 12 },
			"formula": "SUBTOTAL(1, A1:A3)",
			"expected": { "kind": "number", "value": 10 }
		}
	]
}
