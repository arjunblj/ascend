		},
		{
			"description": "CHISQ.INV.RT inverts chi-square upper-tail probability",
			"setup": {},
			"formula": "CHISQ.INV.RT(0.36787944117144233, 2)",
			"expected": { "kind": "number", "approx": 2, "tolerance": 1e-8 }
		},
		{
