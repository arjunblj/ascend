			"expected": { "kind": "number", "value": 0.375 }
		},
		{
			"description": "BINOM.INV returns smallest success count meeting alpha",
			"setup": {},
			"formula": "BINOM.INV(10, 0.5, 0.6)",
			"expected": { "kind": "number", "value": 5 }
		},
		{
			"description": "CHISQ.DIST returns right-skewed chi-square CDF",
