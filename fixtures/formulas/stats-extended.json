{
	"function": "stats-extended",
	"cases": [
		{
			"description": "STDEV.S returns sample standard deviation (same as STDEV)",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "STDEV.S(A1:A3)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "STDEV.P returns population standard deviation",
			"setup": { "A1": 2, "A2": 4, "A3": 4, "A4": 4, "A5": 5, "A6": 5, "A7": 7, "A8": 9 },
			"formula": "STDEV.P(A1:A8)",
			"expected": { "kind": "number", "approx": 2.0, "tolerance": 0.001 }
		},
		{
			"description": "VAR.S returns sample variance (same as VAR)",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "VAR.S(A1:A3)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "VAR.P returns population variance",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "VAR.P(A1:A3)",
			"expected": { "kind": "number", "approx": 0.6667, "tolerance": 0.001 }
		},
		{
			"description": "PERCENTILE.INC is identical to PERCENTILE",
			"setup": { "A1": 1, "A2": 2, "A3": 3, "A4": 4, "A5": 5 },
			"formula": "PERCENTILE.INC(A1:A5, 0.25)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "PERCENTILE.EXC uses n+1 interpolation",
			"setup": { "A1": 1, "A2": 2, "A3": 3, "A4": 4 },
			"formula": "PERCENTILE.EXC(A1:A4, 0.4)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "STDEVP is an alias for population standard deviation",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "STDEVP(A1:A3)",
			"expected": { "kind": "number", "approx": 0.8165, "tolerance": 0.001 }
		},
		{
			"description": "VARP is an alias for population variance",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "VARP(A1:A3)",
			"expected": { "kind": "number", "approx": 0.6667, "tolerance": 0.001 }
		},
		{
			"description": "SUBTOTAL code 6 computes PRODUCT",
			"setup": { "A1": 2, "A2": 3, "A3": 5 },
			"formula": "SUBTOTAL(6, A1:A3)",
			"expected": { "kind": "number", "value": 30 }
		},
		{
			"description": "SUBTOTAL code 7 computes sample STDEV",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "SUBTOTAL(7, A1:A3)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "SUBTOTAL code 8 computes sample VAR",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "SUBTOTAL(8, A1:A3)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "SUBTOTAL code 109 is the hidden-row variant of SUM",
			"setup": { "A1": 10, "A2": 20, "A3": 30 },
			"formula": "SUBTOTAL(109, A1:A3)",
			"expected": { "kind": "number", "value": 60 }
		},
		{
			"description": "SUBTOTAL code 10 computes sample VAR (VAR.S)",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "SUBTOTAL(10, A1:A3)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "SUBTOTAL code 11 computes population VAR (VAR.P)",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "SUBTOTAL(11, A1:A3)",
			"expected": { "kind": "number", "approx": 0.6667, "tolerance": 0.001 }
		},
		{
			"description": "QUARTILE returns 1st quartile",
			"setup": { "A1": 1, "A2": 2, "A3": 3, "A4": 4, "A5": 5 },
			"formula": "QUARTILE(A1:A5, 1)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "QUARTILE returns median at Q2",
			"setup": { "A1": 1, "A2": 2, "A3": 3, "A4": 4, "A5": 5 },
			"formula": "QUARTILE(A1:A5, 2)",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "QUARTILE returns 3rd quartile",
			"setup": { "A1": 1, "A2": 2, "A3": 3, "A4": 4, "A5": 5 },
			"formula": "QUARTILE(A1:A5, 3)",
			"expected": { "kind": "number", "value": 4 }
		},
		{
			"description": "QUARTILE Q0 returns minimum",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "QUARTILE(A1:A3, 0)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "QUARTILE Q4 returns maximum",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "QUARTILE(A1:A3, 4)",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "MODE returns most frequent value",
			"setup": { "A1": 1, "A2": 2, "A3": 2, "A4": 3, "A5": 3, "A6": 3 },
			"formula": "MODE(A1:A6)",
			"expected": { "kind": "number", "value": 3 }
		},
		{
			"description": "MODE with no repeats returns #N/A",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "MODE(A1:A3)",
			"expected": { "kind": "error", "value": "#N/A" }
		},
		{
			"description": "MODE.SNGL is alias for MODE",
			"setup": { "A1": 5, "A2": 5, "A3": 10 },
			"formula": "MODE.SNGL(A1:A3)",
			"expected": { "kind": "number", "value": 5 }
		},
		{
			"description": "LARGE with 10 items k=1 returns max",
			"setup": {
				"A1": 5,
				"A2": 3,
				"A3": 8,
				"A4": 1,
				"A5": 9,
				"A6": 2,
				"A7": 7,
				"A8": 4,
				"A9": 6,
				"A10": 10
			},
			"formula": "LARGE(A1:A10,1)",
			"expected": { "kind": "number", "value": 10 }
		},
		{
			"description": "SMALL with 10 items k=1 returns min",
			"setup": {
				"A1": 5,
				"A2": 3,
				"A3": 8,
				"A4": 1,
				"A5": 9,
				"A6": 2,
				"A7": 7,
				"A8": 4,
				"A9": 6,
				"A10": 10
			},
			"formula": "SMALL(A1:A10,1)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "AGGREGATE(9, 6, range_with_error) SUM ignoring errors",
			"setup": { "A1": 1, "A2": 3, "A3": 5 },
			"setupFormulas": { "A2": "1/0" },
			"formula": "AGGREGATE(9, 6, A1:A3)",
			"expected": { "kind": "number", "value": 6 }
		},
		{
			"description": "AGGREGATE(4, 0, range) MAX with no ignore",
			"setup": { "A1": 2, "A2": 8, "A3": 5 },
			"formula": "AGGREGATE(4, 0, A1:A3)",
			"expected": { "kind": "number", "value": 8 }
		},
		{
			"description": "BETA.DIST returns beta PDF for alpha=2 beta=3",
			"setup": {},
			"formula": "BETA.DIST(0.5, 2, 3, FALSE)",
			"expected": { "kind": "number", "approx": 1.5, "tolerance": 1e-12 }
		},
		{
			"description": "BETA.INV inverts beta CDF for alpha=2 beta=3",
			"setup": {},
			"formula": "BETA.INV(0.6875, 2, 3)",
			"expected": { "kind": "number", "approx": 0.5, "tolerance": 1e-10 }
		},
		{
			"description": "BINOM.DIST returns exact probability mass",
