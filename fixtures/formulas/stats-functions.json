{
	"function": "stats",
	"cases": [
		{
			"description": "LARGE returns the 2nd largest number",
			"setup": { "A1": 1, "A2": 2, "A3": 3, "A4": 4, "A5": 5 },
			"formula": "LARGE(A1:A5, 2)",
			"expected": { "kind": "number", "value": 4 }
		},
		{
			"description": "SMALL returns the 2nd smallest number",
			"setup": { "A1": 1, "A2": 2, "A3": 3, "A4": 4, "A5": 5 },
			"formula": "SMALL(A1:A5, 2)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "RANK returns descending rank by default",
			"setup": { "A1": 10, "A2": 20, "A3": 30 },
			"formula": "RANK(20, A1:A3)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "PERCENTILE interpolates over a simple ordered set",
			"setup": { "A1": 1, "A2": 2, "A3": 3, "A4": 4, "A5": 5 },
			"formula": "PERCENTILE(A1:A5, 0.25)",
			"expected": { "kind": "number", "value": 2 }
		},
		{
			"description": "MEDIAN averages the middle pair for an even-sized set",
			"setup": { "A1": 1, "A2": 2, "A3": 3, "A4": 4 },
			"formula": "MEDIAN(A1:A4)",
			"expected": { "kind": "number", "value": 2.5 }
		},
		{
			"description": "STDEV returns sample standard deviation",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "STDEV(A1:A3)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "VAR returns sample variance",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "VAR(A1:A3)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "LARGE returns #NUM! when k exceeds the result set",
			"setup": { "A1": 1, "A2": 2, "A3": 3 },
			"formula": "LARGE(A1:A3, 5)",
			"expected": { "kind": "error", "value": "#NUM!" }
		},
		{
			"description": "RANK supports ascending order for race times",
			"setup": { "A1": 10, "A2": 20, "A3": 30 },
			"formula": "RANK(10, A1:A3, 1)",
			"expected": { "kind": "number", "value": 1 }
		},
		{
			"description": "PERCENTILE interpolates non-trivially across an even set",
			"setup": { "A1": 1, "A2": 2, "A3": 3, "A4": 4 },
			"formula": "PERCENTILE(A1:A4, 0.25)",
			"expected": { "kind": "number", "value": 1.75 }
		},
		{
			"description": "STDEV returns #DIV/0! for a single value",
			"setup": { "A1": 5 },
			"formula": "STDEV(A1)",
			"expected": { "kind": "error", "value": "#DIV/0!" }
		}
	]
}
