{
	"name": "ascend",
	"private": true,
	"workspaces": [
		"packages/*",
		"apps/*",
		"fixtures/*"
	],
	"scripts": {
		"typecheck": "tsc --build",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"test": "bun test --recursive",
		"corpus:audit": "bun run fixtures/corpus/audit.ts",
		"bench": "bun run fixtures/benchmarks/run.ts",
		"bench:real": "bun run fixtures/benchmarks/real-workbook.ts",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@types/bun": "^1.3.10",
		"lefthook": "^1.11.0",
		"typescript": "^5.7.0"
	}
}
